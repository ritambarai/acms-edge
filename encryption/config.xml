<board-stage>
    <!-- acms-secure-init: binds LUKS2 root to this board's SID on first boot -->
    <file src="acms-secure-init.sh"      dest="usr/local/bin" />
    <file src="acms-secure-init.service" dest="etc/systemd/system" />

    <!-- initramfs keyscript: derives LUKS key from Allwinner A20 SID fuse.
         name= renames the file so initramfs-tools picks it up by the right path. -->
    <file src="acms_keyscript.hook" dest="etc/initramfs-tools/hooks"   name="acms_keyscript" />
    <file src="acms_sid_keyscript"  dest="etc/initramfs-tools/scripts" name="acms-sid-key" />
</board-stage>
