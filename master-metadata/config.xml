<?xml version="1.0" encoding="UTF-8"?>
<!--
  ACMS Metadata Config — key-option ladder.

  Only classes that have defined key options need to appear here.
  Classes without options are simply not listed.

  Nesting rule:
    <class name="PLC">
      <key name="slave">          ← PLC has key "slave"
        <key name="id"/>          ← values of "slave" inherit these as sub-keys
        <key name="numSlots"/>
      </key>
    </class>

  If a nested key itself has children, that sub-level is applied the same
  way — values typed for that key inherit its children as key options.
-->
<Config>

  <!-- Root classes without key options — appear in Class dropdown only -->
  <class name="Fault_Code"/>
  <class name="dataType"/>

  <!-- Card mirrors PLC: "name" key holds card instances (like PLC's "slave").
       Each instance inherits fn_id, fn_name, numPins, Start_Addr as its sub-keys. -->
  <class name="Card">
    <key name="label">
      <key name="ID"/>
      <key name="Name"/>
      <key name="numPins"/>
      <key name="Start_Addr"/>
    </key>
  </class>

  <!-- PLC: top-level keys are type, class, and node.
       class values (pumps, pipes, …) inherit variable as their sub-key.
       node values (PLC1, PLC2, …) inherit id and numSlots as their sub-keys. -->
  <class name="PLC">
    <key name="type"/>
    <key name="class">
      <key name="variable">
        <key name="dataType"/>
        <key name="unit"/>
        <key name="Fault_Code"/>
        <key name="Card"/>
      </key>
      <key name="field"/>
      <key name="variables"/>
    </key>
    <key name="node">
      <key name="ID"/>
      <key name="numSlots"/>
      <key name="field"/>
    </key>
  </class>

</Config>
