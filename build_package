#!/bin/sh
#
# build_package
#
# Builds an opkg (.ipk) from a directory of files.
# Auto-generates install.sh based on file types (top-level files only):
#
#   ELF binary or .sh  →  /usr/local/bin/   + chmod +x
#   .service           →  /etc/systemd/system/ + systemctl enable
#   other              →  /etc/acms/
#
# The generated install.sh defaults stateCode to 0 (Running).
# Pass a different stateCode as the third argument to override.
# You can also manually edit the generated install.sh inside the .ipk
# by extracting, editing, and re-packing before deploying.
#
# After a successful pack the top-level files in the input directory are cleared.
#
# Flags:
#   -f         Force: ignore any existing install.sh and regenerate from scratch.
#              Without -f, an existing install.sh is preserved so manual edits survive.
#   -c/--copy  Archive: save install.sh and a file manifest to archives/.
#              Requires an output path.  Archives are written to archives/ next to
#              this script (override with ACMS_ARCHIVE_DIR env var):
#                archives/<output_stem>.sh   — the install.sh used for this build
#                archives/<output_stem>.csv  — manifest: filename,destination
#
# Requires: ar, tar, od
#
# Usage:
#   build_package [-f] [-c] [input_dir]                    # generate install.sh only (default: packages/)
#   build_package [-f] [-c] [input_dir] <output.ipk> [N]  # pack .ipk
#
# Examples:
#   build_package                                          # use packages/ as input dir
#   build_package packages/my_pkg                          # write install.sh for review
#   build_package packages/my_pkg my_pkg.ipk               # pack with stateCode=0
#   build_package packages/my_pkg my_pkg.ipk 3             # pack with stateCode=3
#   build_package -f packages/my_pkg my_pkg.ipk            # regenerate install.sh, then pack
#   build_package -c packages/my_pkg my_pkg.ipk            # pack and archive install.sh + manifest

set -eu

# Archives land next to this script unless overridden (useful for testing)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ARCHIVE_DIR="${ACMS_ARCHIVE_DIR:-"$SCRIPT_DIR/archives"}"

FORCE=0
COPY=0
while [ $# -gt 0 ]; do
    case "$1" in
        -f)       FORCE=1; shift ;;
        -c|--copy) COPY=1; shift ;;
        -*) echo "ERROR: unknown option: $1" >&2
            echo "Usage: $0 [-f] [-c] [input_dir] [output.ipk] [next_state_code]" >&2
            exit 1 ;;
        *)  break ;;
    esac
done

INPUT_DIR="${1:-packages}"
OUTPUT="${2:-}"
NEXT_STATE="${3:-0}"

if [ ! -d "$INPUT_DIR" ]; then
    echo "ERROR: input directory not found: $INPUT_DIR" >&2
    exit 1
fi

if [ "$COPY" = "1" ] && [ -z "$OUTPUT" ]; then
    echo "ERROR: -c/--copy requires an output path" >&2
    exit 1
fi

TMP_DIR="$(mktemp -d /tmp/build_pkg_XXXXXX)"
DATA_DIR="$TMP_DIR/data"
CTRL_DIR="$TMP_DIR/control"
INSTALL_SH="$INPUT_DIR/install.sh"   # written to input_dir so it is editable
INSTALL_SH_GENERATED=0

cleanup() { rm -rf "$TMP_DIR"; }
trap cleanup EXIT

mkdir -p "$DATA_DIR" "$CTRL_DIR"

# ── classify and place files (top-level only — no subdirectories) ─────────────

BINS=""       # files going to /usr/local/bin (need chmod +x)
SERVICES=""   # .service files (need systemctl enable)
FILE_LIST=""  # CSV rows: filename,/destination

for _src in "$INPUT_DIR"/*; do
    [ -f "$_src" ] || continue          # skip subdirectories
    _name="$(basename "$_src")"
    [ "$_name" = "install.sh" ] && continue   # not a payload file

    # determine destination by type
    case "$_name" in
        *.service)
            _dest="etc/systemd/system/$_name"
            SERVICES="$SERVICES $_name"
            ;;
        *.sh)
            _dest="usr/local/bin/$_name"
            BINS="$BINS $_name"
            ;;
        *)
            # check for ELF binary
            if od -A n -t x1 -N 4 "$_src" 2>/dev/null | grep -q '7f 45 4c 46'; then
                _dest="usr/local/bin/$_name"
                BINS="$BINS $_name"
            else
                _dest="etc/acms/$_name"
            fi
            ;;
    esac

    FILE_LIST="${FILE_LIST}${_name},/${_dest}
"
    mkdir -p "$DATA_DIR/$(dirname "$_dest")"
    cp -p "$_src" "$DATA_DIR/$_dest"
    echo "  $INPUT_DIR/$_name  →  /$_dest"
done

# ── generate install.sh (skip if already exists — preserves edits) ────────────

if [ -f "$INSTALL_SH" ] && [ "$FORCE" = "0" ]; then
    echo "install.sh already exists — using existing (edits preserved)"
else
    [ -f "$INSTALL_SH" ] && echo "Regenerating install.sh (-f flag)"

INSTALL_SH_GENERATED=1
cat > "$INSTALL_SH" <<'HEADER'
#!/bin/sh
#
# install.sh — auto-generated by build_package
# Edit stateCode below to advance the board lifecycle after install.
# All other sections are derived from the package contents.

set -e

HEADER

# chmod for binaries and scripts
if [ -n "$BINS" ]; then
    echo "# make executables runnable" >> "$INSTALL_SH"
    for _b in $BINS; do
        echo "chmod +x /usr/local/bin/$_b" >> "$INSTALL_SH"
    done
    echo "" >> "$INSTALL_SH"
fi

# enable services
if [ -n "$SERVICES" ]; then
    echo "# enable systemd services" >> "$INSTALL_SH"
    for _s in $SERVICES; do
        echo "systemctl enable $_s" >> "$INSTALL_SH"
    done
    echo "" >> "$INSTALL_SH"
fi

# stateCode — override by changing the value
cat >> "$INSTALL_SH" <<FOOTER
# next board state after install (change if this package requires a specific state)
printf 'stateCode=%s\n' ${NEXT_STATE} > "\$ACMS_BOARD_STATE"

exit 0
FOOTER

chmod +x "$INSTALL_SH"
echo ""
echo "Generated: $INSTALL_SH"

fi  # end of generate block

sed 's/^/  /' "$INSTALL_SH"

# ── stop here if no output requested — let user edit install.sh first ─────────

if [ -z "$OUTPUT" ]; then
    if [ "$INSTALL_SH_GENERATED" = "1" ]; then
        echo ""
        echo "Review and edit $INSTALL_SH, then run:"
        echo "  $0 $INPUT_DIR <output.ipk> [next_state_code]"
    else
        echo ""
        echo "Using existing install.sh. Run with output arg to pack:"
        echo "  $0 $INPUT_DIR <output.ipk> [next_state_code]"
    fi
    exit 0
fi

# ── pack archives ─────────────────────────────────────────────────────────────

echo ""
echo "Packing..."

cp "$INSTALL_SH" "$CTRL_DIR/install.sh"

DATA_TAR="$TMP_DIR/data.tar.gz"
CTRL_TAR="$TMP_DIR/control.tar.gz"
DEBIAN_BIN="$TMP_DIR/debian-binary"

printf '2.0\n' > "$DEBIAN_BIN"

( cd "$DATA_DIR" && tar -czf "$DATA_TAR" . )
( cd "$CTRL_DIR" && tar -czf "$CTRL_TAR" . )

( cd "$TMP_DIR" && ar rcs "$(realpath "$OUTPUT")" debian-binary control.tar.gz data.tar.gz )

echo "Built: $OUTPUT"

# ── archive install.sh and file manifest (-c/--copy) ─────────────────────────

if [ "$COPY" = "1" ]; then
    OUTPUT_STEM="$(basename "$OUTPUT" .ipk)"
    mkdir -p "$ARCHIVE_DIR"

    cp "$INSTALL_SH" "$ARCHIVE_DIR/${OUTPUT_STEM}.sh"
    printf 'filename,destination\n%s' "$FILE_LIST" > "$ARCHIVE_DIR/${OUTPUT_STEM}.csv"

    echo "Archived: $ARCHIVE_DIR/${OUTPUT_STEM}.sh"
    echo "Archived: $ARCHIVE_DIR/${OUTPUT_STEM}.csv"
fi

# ── clear input directory after successful pack ───────────────────────────────

echo "Clearing: $INPUT_DIR"
find "$INPUT_DIR" -maxdepth 1 -type f -delete
